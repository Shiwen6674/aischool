              button.classList.remove('active');
            } else {
              this.state.activePos.add(pos);
              button.classList.add('active');
            }
            if (this.state.words.length) {
              this.renderWordCloud();
              this.updateMetrics();
            }
          });
        });
        window.addEventListener('resize', () => this.scheduleWordCloudRender());
      },
      setupBackLink() {
        const params = new URLSearchParams(location.search);
        const referrer = document.referrer || '';
        let referrerFrom = '';
        try {
          const referrerPath = new URL(referrer).pathname.toLowerCase();
          if (referrerPath.endsWith('/professor.html') || referrerPath.endsWith('professor.html')) referrerFrom = 'professor';
          if (referrerPath.endsWith('/researcher.html') || referrerPath.endsWith('researcher.html')) referrerFrom = 'researcher';
        } catch {}
        const from = params.get('from') || sessionStorage.getItem('wordcloud_from') || referrerFrom || 'professor';
        sessionStorage.setItem('wordcloud_from', from);
        const target = from === 'researcher' ? 'researcher.html' : 'professor.html';
        document.getElementById('back-link-trigger').addEventListener('click', () => {
          window.location.href = target;
        });
      },
      applyTranslations() {
        document.documentElement.lang = this.state.currentLang;
        document.getElementById('language-selector').value = this.state.currentLang;
        document.getElementById('font-select').value = this.state.currentFont;
        document.querySelectorAll('[data-i18n]').forEach((element) => {
          const key = element.getAttribute('data-i18n');
          element.textContent = this.t(key);
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach((element) => {
          const key = element.getAttribute('data-i18n-placeholder');
          element.setAttribute('placeholder', this.t(key));
        });
      },
      loadExample() {
        document.getElementById('text-input').value = this.exampleText;
      },
      clearInput() {
        document.getElementById('text-input').value = '';
        this.state.words = [];
        this.state.aiHtml = '';
        document.getElementById('panel-ai').innerHTML = `<div class="rounded-2xl border border-dashed border-brand-200 bg-white/70 p-5 text-slate-500">${this.t('panel_ai_placeholder')}</div>`;
        this.renderTable([]);
        this.updateMetrics();
        this.resetCanvasState();
        this.toggleDownloads(false);
        this.setStatus('empty', this.t('state_ready'), this.t('state_ready_desc'));
      },
      resetCanvasState() {
        const canvas = document.getElementById('word-cloud-canvas');
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width || 1, canvas.height || 1);
        canvas.classList.add('hidden');
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('loading-state').classList.remove('grid');
        document.getElementById('filter-empty-state').classList.add('hidden');
        document.getElementById('filter-empty-state').classList.remove('grid');
        document.getElementById('empty-state').classList.remove('hidden');
        document.getElementById('empty-state').classList.add('grid');
      },
      setStatus(type, title, message) {
        const banner = document.getElementById('status-banner');
        const icon = document.getElementById('status-icon');
        banner.className = `status-banner status-${type}`;
        document.getElementById('status-title').textContent = title;
        document.getElementById('status-message').textContent = message;
        const iconByType = {
          ready: 'fa-regular fa-circle',
          empty: 'fa-regular fa-circle',
          loading: 'fa-solid fa-spinner fa-spin',
          success: 'fa-solid fa-circle-check',
          error: 'fa-solid fa-triangle-exclamation'
        };
        icon.className = `${iconByType[type] || iconByType.ready} mt-1`;
      },
      toggleDownloads(enabled) {
        ['btn-download-image', 'btn-download-txt', 'btn-download-pdf'].forEach((id) => {
          document.getElementById(id).disabled = !enabled;
        });
      },
      getFontPreset() {
        const fonts = {
          sans: {
            family: '"Inter", "Noto Sans TC", sans-serif',
            load: ['"Inter"', '"Noto Sans TC"'],
            rotateRatio: 0.08
          },
          serif: {
            family: '"Noto Serif TC", "Noto Sans TC", serif',
            load: ['"Noto Serif TC"'],
            rotateRatio: 0.04
          },
          playful: {
            family: '"ZCOOL KuaiLe", "Noto Sans TC", sans-serif',
            load: ['"ZCOOL KuaiLe"'],
            rotateRatio: 0
          }
        };
        return fonts[this.state.currentFont] || fonts.sans;
      },
      async ensureFontReady() {
        if (!document.fonts) return;
        const preset = this.getFontPreset();
        await Promise.all((preset.load || []).map((family) => document.fonts.load(`700 24px ${family}`)));
      },
      normalizePos(pos) {
        const p = String(pos || 'o').toLowerCase().charAt(0);
        return ['n', 'v', 'a', 'd', 'c'].includes(p) ? p : 'o';
      },
      getVisibleWords() {
        return this.state.words.slice(0, this.state.maxWords);
      },
      getFilteredWords() {
        return this.getVisibleWords().filter((item) => this.state.activePos.has(this.normalizePos(item.pos)));
      },
      updateMetrics() {
        const visible = this.getVisibleWords();
        document.getElementById('metric-total-terms').textContent = this.state.words.length;
        document.getElementById('metric-visible-terms').textContent = this.getFilteredWords().length;
        document.getElementById('metric-top-word').textContent = visible[0] ? visible[0].word : '-';
      },
      async runAnalysis() {
        const text = document.getElementById('text-input').value.trim();
        const button = document.getElementById('btn-analyze');
        if (!text) {
          this.showToast(this.t('msg_input_empty'), 'error');
          return;
        }
        if (!GAS_URL || GAS_URL.includes('在此填入')) {
          this.showToast('GAS URL 未設定', 'error');
          return;
        }
        this.state.analyzing = true;
        this.setStatus('loading', this.t('state_loading'), this.t('state_loading_desc'));
        document.getElementById('empty-state').classList.add('hidden');
        document.getElementById('empty-state').classList.remove('grid');
        document.getElementById('filter-empty-state').classList.add('hidden');
        document.getElementById('filter-empty-state').classList.remove('grid');
        document.getElementById('loading-state').classList.remove('hidden');
        document.getElementById('loading-state').classList.add('grid');
        document.getElementById('word-cloud-canvas').classList.add('hidden');
        this.toggleDownloads(false);
        const original = button.innerHTML;
        button.disabled = true;
        button.innerHTML = `<span class="loader h-5 w-5 border-[3px] border-white/30 border-t-white"></span><span>${this.t('msg_processing')}</span>`;
        try {
          const response = await fetch(GAS_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({
              text,
              mode: document.getElementById('model-select').value,
              maxTerms: this.state.maxWords
            })
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const json = await response.json();
          if (json.status !== 'success' || !json.data || !Array.isArray(json.data.wordList)) {
            throw new Error(json.message || 'Invalid response payload');
          }
          this.state.words = json.data.wordList;
          this.state.aiHtml = json.data.aiAnalysis || '';
          document.getElementById('panel-ai').innerHTML = this.state.aiHtml || `<div class="rounded-2xl border border-dashed border-brand-200 bg-white/70 p-5 text-slate-500">${this.t('panel_ai_placeholder')}</div>`;
          this.renderTable(this.getVisibleWords());
          this.updateMetrics();
          this.switchTab('ai');
          this.renderWordCloud();
          this.toggleDownloads(true);
          this.setStatus('success', this.t('state_success'), this.t('state_success_desc'));
          this.showToast(this.t('msg_success'));
        } catch (error) {
          console.error(error);
          this.state.words = [];
          this.state.aiHtml = '';
          this.renderTable([]);
          this.updateMetrics();
          this.resetCanvasState();
          this.setStatus('error', this.t('state_error'), `${this.t('msg_error')}: ${error.message}`);
          this.showToast(`${this.t('msg_error')}: ${error.message}`, 'error');
        } finally {
          this.state.analyzing = false;
          button.disabled = false;
          button.innerHTML = original;
          document.getElementById('loading-state').classList.add('hidden');
          document.getElementById('loading-state').classList.remove('grid');
        }
      },
      scheduleWordCloudRender() {
        if (!this.state.words.length || this.state.analyzing) return;
        window.clearTimeout(this.state.redrawTimer);
        this.state.redrawTimer = window.setTimeout(() => this.renderWordCloud(), 120);
      },
      async renderWordCloud() {
        if (typeof WordCloud !== 'function') {
          this.showToast(this.t('msg_library_missing'), 'error');
          return;
        }
        await this.ensureFontReady();
        const canvas = document.getElementById('word-cloud-canvas');
        const wrapper = document.getElementById('canvas-wrapper');
        const filteredList = this.getFilteredWords();
        const fontPreset = this.getFontPreset();
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('loading-state').classList.remove('grid');
        document.getElementById('empty-state').classList.add('hidden');
        document.getElementById('empty-state').classList.remove('grid');
        if (!filteredList.length) {
          const ctx = canvas.getContext('2d');
          ctx.clearRect(0, 0, canvas.width || 1, canvas.height || 1);
          canvas.classList.add('hidden');
          document.getElementById('filter-empty-state').classList.remove('hidden');
          document.getElementById('filter-empty-state').classList.add('grid');
          this.showToast(this.t('msg_filter_empty'), 'error');
          return;
        }
        document.getElementById('filter-empty-state').classList.add('hidden');
        document.getElementById('filter-empty-state').classList.remove('grid');
        canvas.classList.remove('hidden');
        const width = Math.max(wrapper.clientWidth - 96, 300);
        const height = Math.max(wrapper.clientHeight - 96, 300);
        canvas.width = width;
        canvas.height = height;
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        const maxWeight = Math.max(...filteredList.map((item) => Number(item.weight) || 0), 1);
        const list = filteredList.map((item) => [item.word, Math.max(18, Math.round(((Number(item.weight) || 0) / maxWeight) * 54 + 14))]);
        WordCloud(canvas, {
          list,
          gridSize: Math.max(10, Math.round(width / 70)),
          weightFactor: 1,
          fontFamily: fontPreset.family,
          fontWeight: 800,
          color: (word) => {
            const item = filteredList.find((entry) => entry.word === word);
            return this.getPosColor(item ? item.pos : 'o');
          },
          rotateRatio: fontPreset.rotateRatio,
          rotationSteps: 2,
          minRotation: -Math.PI / 4,
          maxRotation: Math.PI / 4,
          shape: document.getElementById('shape-select').value,
          ellipticity: 0.72,
          backgroundColor: 'rgba(255,255,255,0)',
          drawOutOfBound: false,
          shrinkToFit: true,
          shuffle: false,
          clearCanvas: true
        });
      },
      getPosColor(pos) {
        const p = this.normalizePos(pos);
        if (p === 'n') return '#2563eb';
        if (p === 'v') return '#dc2626';
        if (p === 'a') return '#16a34a';
        if (p === 'd') return '#d97706';
        if (p === 'c') return '#ec4899';
        return '#64748b';
      },
      getPosBadgeClass(pos) {
        const p = this.normalizePos(pos);
        if (p === 'n') return 'bg-blue-50 text-blue-700';
        if (p === 'v') return 'bg-red-50 text-red-700';
        if (p === 'a') return 'bg-emerald-50 text-emerald-700';
        if (p === 'd') return 'bg-amber-50 text-amber-700';
        if (p === 'c') return 'bg-pink-50 text-pink-700';
        return 'bg-slate-100 text-slate-600';
      },
      renderTable(list) {
        const tbody = document.getElementById('data-table-body');
        if (!list.length) {
          tbody.innerHTML = `<tr><td colspan="4" class="px-4 py-10 text-center text-slate-400">${this.t('msg_no_results')}</td></tr>`;
          return;
        }
        tbody.innerHTML = list.map((item, index) => `
          <tr class="transition hover:bg-slate-50">
            <td class="font-mono text-xs text-slate-400">${index + 1}</td>
            <td class="font-bold text-slate-800">${this.escapeHtml(item.word)}</td>
            <td><span class="inline-flex rounded-full px-2.5 py-1 text-xs font-black ${this.getPosBadgeClass(item.pos)}">${this.escapeHtml(item.pos || 'O')}</span></td>
            <td class="text-right font-mono text-sm font-bold text-slate-600">${Number(item.weight || 0).toFixed(2)}</td>
          </tr>
        `).join('');
      },
      switchTab(tab) {
        const aiButton = document.getElementById('tab-ai');
        const dataButton = document.getElementById('tab-data');
        document.getElementById('panel-ai').classList.toggle('hidden', tab === 'data');
        document.getElementById('panel-data').classList.toggle('hidden', tab !== 'data');
        aiButton.classList.toggle('active', tab !== 'data');
        dataButton.classList.toggle('active', tab === 'data');
      },
      escapeHtml(text) {
        return String(text).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
      },
      getCanvasImage() {
        const source = document.getElementById('word-cloud-canvas');
        const temp = document.createElement('canvas');
        temp.width = source.width;
        temp.height = source.height;
        const ctx = temp.getContext('2d');
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, temp.width, temp.height);
        ctx.drawImage(source, 0, 0);
        return temp.toDataURL('image/png');
      },
      async downloadReport(type) {
        if (!this.state.words.length) {
          this.showToast(this.t('msg_no_results'), 'error');
          return;
        }
        if (type === 'txt') {
          const content = [
            this.t('title'),
            '',
            '=== AI Insight ===',
            document.getElementById('panel-ai').innerText.trim(),
            '',
            '=== Data ===',
            'Rank\tWord\tPOS\tWeight',
            ...this.getVisibleWords().map((item, index) => `${index + 1}\t${item.word}\t${item.pos}\t${Number(item.weight || 0).toFixed(2)}`)
          ].join('\n');
          const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
          const link = document.createElement('a');
          link.href = URL.createObjectURL(blob);
          link.download = `wordcloud_report_${Date.now()}.txt`;
          link.click();
          URL.revokeObjectURL(link.href);
          this.showToast(this.t('msg_txt_success'));
          return;
        }
        this.showToast(this.t('msg_pdf_working'));
        const container = document.getElementById('pdf-generator-container');
        const visibleWords = this.getVisibleWords();
        try {
          const { jsPDF } = window.jspdf;
          const pdf = new jsPDF('p', 'mm', 'a4');
          const margin = 8;
          const usableWidth = pdf.internal.pageSize.getWidth() - margin * 2;
          const usableHeight = pdf.internal.pageSize.getHeight() - margin * 2;
          const addCanvasImage = (render, addPage = false) => {
            const image = render.toDataURL('image/png');
            if (addPage) pdf.addPage();
            const imageHeight = render.height * usableWidth / render.width;
            pdf.addImage(image, 'PNG', margin, margin, usableWidth, imageHeight);
          };
          const coverHtml = `
            <div style="font-family:'Inter','Noto Sans TC',sans-serif;color:#334155;">
              <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:18px;margin-bottom:24px;">
                <div>
                  <div style="display:inline-flex;align-items:center;gap:8px;padding:8px 14px;border-radius:999px;background:#faf5ff;border:1px solid #e9d5ff;color:#7e22ce;font-size:12px;font-weight:800;">Professor Workspace</div>
                  <h1 style="margin:14px 0 8px;color:#581c87;font-size:30px;">${this.escapeHtml(this.t('title'))}</h1>
                  <p style="margin:0;color:#64748b;font-size:14px;line-height:1.7;">${this.escapeHtml(this.t('subtitle'))}</p>
                </div>
                <div style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:18px;background:#fff;min-width:180px;">
                  <div style="font-size:12px;color:#94a3b8;font-weight:800;text-transform:uppercase;">Generated</div>
                  <div style="margin-top:6px;font-size:14px;font-weight:700;color:#334155;">${this.escapeHtml(new Date().toLocaleString())}</div>
                </div>
              </div>
              <div style="border:1px solid #e2e8f0;border-radius:24px;padding:18px;background:linear-gradient(180deg,#fff 0%,#faf5ff 100%);margin-bottom:24px;">
                <img src="${this.getCanvasImage()}" style="width:100%;border-radius:16px;">
              </div>
              <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px;">
                <div style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:18px;background:#fff;"><div style="font-size:12px;color:#94a3b8;font-weight:800;text-transform:uppercase;">Terms</div><div style="margin-top:8px;font-size:24px;font-weight:900;color:#334155;">${this.state.words.length}</div></div>
                <div style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:18px;background:#fff;"><div style="font-size:12px;color:#94a3b8;font-weight:800;text-transform:uppercase;">Visible</div><div style="margin-top:8px;font-size:24px;font-weight:900;color:#334155;">${this.getFilteredWords().length}</div></div>
                <div style="padding:14px 16px;border:1px solid #e2e8f0;border-radius:18px;background:#fff;"><div style="font-size:12px;color:#94a3b8;font-weight:800;text-transform:uppercase;">Top Term</div><div style="margin-top:8px;font-size:22px;font-weight:900;color:#334155;">${this.escapeHtml(visibleWords[0]?.word || '-')}</div></div>
              </div>
              <div style="border:1px solid #e2e8f0;border-radius:24px;padding:24px;background:#fff;">
                <h2 style="margin:0 0 12px;color:#334155;font-size:20px;">AI Insight</h2>
                <div style="font-size:15px;line-height:1.85;color:#475569;">${document.getElementById('panel-ai').innerHTML}</div>
              </div>
            </div>`;
          container.innerHTML = coverHtml;
          const coverRender = await html2canvas(container, { scale: 2, backgroundColor: '#ffffff', useCORS: true });
          const coverHeight = coverRender.height * usableWidth / coverRender.width;
          if (coverHeight <= usableHeight) {
            addCanvasImage(coverRender, false);
          } else {
            const image = coverRender.toDataURL('image/png');
            let remainingHeight = coverHeight;
            let positionY = margin;
            pdf.addImage(image, 'PNG', margin, positionY, usableWidth, coverHeight);
            remainingHeight -= usableHeight;
            while (remainingHeight > 0) {
              positionY -= usableHeight;
              pdf.addPage();
              pdf.addImage(image, 'PNG', margin, positionY, usableWidth, coverHeight);
              remainingHeight -= usableHeight;
            }
          }

          const rowsPerPage = 14;
          for (let pageIndex = 0; pageIndex < visibleWords.length; pageIndex += rowsPerPage) {
            const chunk = visibleWords.slice(pageIndex, pageIndex + rowsPerPage);
            const rows = chunk.map((item, index) => `
              <tr style="background:${index % 2 === 0 ? '#ffffff' : '#faf5ff'};">
                <td style="padding:11px 12px;border-bottom:1px solid #ede9fe;">${pageIndex + index + 1}</td>
                <td style="padding:11px 12px;border-bottom:1px solid #ede9fe;font-weight:700;">${this.escapeHtml(item.word)}</td>
                <td style="padding:11px 12px;border-bottom:1px solid #ede9fe;">${this.escapeHtml(item.pos || 'O')}</td>
                <td style="padding:11px 12px;border-bottom:1px solid #ede9fe;text-align:right;">${Number(item.weight || 0).toFixed(2)}</td>
              </tr>`).join('');
            container.innerHTML = `
              <div style="font-family:'Inter','Noto Sans TC',sans-serif;color:#334155;">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
                  <div>
                    <h2 style="margin:0;color:#334155;font-size:22px;">Top Terms</h2>
                    <p style="margin:6px 0 0;color:#64748b;font-size:13px;">Rows ${pageIndex + 1}-${pageIndex + chunk.length}</p>
                  </div>
                  <div style="padding:8px 12px;border-radius:999px;background:#faf5ff;border:1px solid #e9d5ff;color:#7e22ce;font-size:12px;font-weight:800;">Page ${Math.floor(pageIndex / rowsPerPage) + 1}</div>
                </div>
                <table style="width:100%;border-collapse:collapse;font-size:13px;background:#fff;border:1px solid #e2e8f0;border-radius:20px;overflow:hidden;">
                  <thead>
                    <tr style="background:#f8fafc;">
                      <th style="padding:11px 12px;text-align:left;">#</th>
                      <th style="padding:11px 12px;text-align:left;">Word</th>
                      <th style="padding:11px 12px;text-align:left;">POS</th>
                      <th style="padding:11px 12px;text-align:right;">Weight</th>
                    </tr>
                  </thead>
                  <tbody>${rows}</tbody>
                </table>
              </div>`;
            const tableRender = await html2canvas(container, { scale: 2, backgroundColor: '#ffffff', useCORS: true });
            addCanvasImage(tableRender, true);
          }
          pdf.save(`wordcloud_report_${Date.now()}.pdf`);
          this.showToast(this.t('msg_pdf_success'));
        } catch (error) {
          console.error(error);
          this.showToast(this.t('msg_pdf_error'), 'error');
        } finally {
          container.innerHTML = '';
        }
      },
      downloadImage() {
        if (!this.state.words.length) {
          this.showToast(this.t('msg_no_results'), 'error');
          return;
        }
        const link = document.createElement('a');
        link.download = `wordcloud_${Date.now()}.png`;
        link.href = this.getCanvasImage();
        link.click();
        this.showToast(this.t('msg_img_success'));
      },
      showToast(message, type = 'info') {
        const toast = document.getElementById('toast');
        document.getElementById('toast-msg').textContent = message;
        toast.className = 'toast show rounded-full px-5 py-3 text-sm font-bold shadow-2xl';
        toast.classList.add(type === 'error' ? 'bg-red-600' : 'bg-slate-900', 'text-white');
        window.clearTimeout(this.state.toastTimer);
        this.state.toastTimer = window.setTimeout(() => toast.classList.remove('show'), 2600);
      }
    };
    App.init();
  </script>
</body>
