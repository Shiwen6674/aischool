<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI智能文字雲生成器 | Science Learning Hub</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/wordcloud2.js/1.2.2/wordcloud2.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+TC:wght@400;500;700;900&family=Noto+Serif+TC:wght@500;700;900&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            researcher: { light: '#e9d5ff', DEFAULT: '#a855f7', dark: '#7e22ce' },
            brand: {
              50: '#faf5ff',
              100: '#f3e8ff',
              200: '#e9d5ff',
              300: '#d8b4fe',
              400: '#c084fc',
              500: '#a855f7',
              600: '#9333ea',
              700: '#7e22ce',
              800: '#6b21a8',
              900: '#581c87'
            }
          },
          fontFamily: {
            sans: ['Inter', 'Noto Sans TC', 'sans-serif'],
            mono: ['JetBrains Mono', 'Consolas', 'monospace']
          },
          boxShadow: {
            float: '0 24px 48px rgba(126, 34, 206, 0.12)',
            soft: '0 10px 30px rgba(15, 23, 42, 0.06)'
          }
        }
      }
    }
  </script>
  <style>
    :root {
      color-scheme: light;
      --bg-main: #f8fafc;
      --bg-tint: #fdfbff;
      --panel: rgba(255, 255, 255, 0.92);
      --panel-border: rgba(226, 232, 240, 0.9);
      --text-main: #334155;
      --text-soft: #64748b;
      --brand: #a855f7;
      --brand-ring: rgba(168, 85, 247, 0.16);
      --noun: #2563eb;
      --verb: #dc2626;
      --adj: #16a34a;
      --adv: #d97706;
      --conj: #ec4899;
      --other: #64748b;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(233, 213, 255, 0.65), transparent 34%),
        radial-gradient(circle at bottom right, rgba(196, 181, 253, 0.35), transparent 28%),
        linear-gradient(135deg, var(--bg-tint) 0%, var(--bg-main) 55%, #f3f4f6 100%);
      color: var(--text-main);
      font-family: 'Inter', 'Noto Sans TC', sans-serif;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.45) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.45) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: radial-gradient(circle at center, black 35%, transparent 85%);
      pointer-events: none;
      z-index: -2;
    }

    .glass-panel {
      background: var(--panel);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--panel-border);
      box-shadow: 0 10px 35px rgba(15, 23, 42, 0.06);
    }

    .focus-ring:focus,
    .focus-ring:focus-visible {
      outline: none;
      border-color: var(--brand);
      box-shadow: 0 0 0 4px var(--brand-ring);
    }

    .title-3d {
      background: linear-gradient(135deg, #581c87 0%, #7e22ce 48%, #a855f7 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      filter: drop-shadow(1px 1px 0 rgba(168, 85, 247, 0.3));
    }

    .nav-chip {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .5rem .85rem;
      border-radius: 999px;
      border: 1px solid rgba(216, 180, 254, 0.8);
      background: rgba(250, 245, 255, 0.88);
      color: #7e22ce;
      font-size: .82rem;
      font-weight: 800;
      letter-spacing: .01em;
    }

    .soft-scroll::-webkit-scrollbar { width: 8px; height: 8px; }
    .soft-scroll::-webkit-scrollbar-track { background: transparent; }
    .soft-scroll::-webkit-scrollbar-thumb { background: rgba(148, 163, 184, 0.28); border-radius: 999px; }
    .soft-scroll::-webkit-scrollbar-thumb:hover { background: rgba(148, 163, 184, 0.45); }

    .pos-chip {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      min-height: 42px;
      padding: .65rem .9rem;
      border-radius: 1rem;
      border: 1px solid #e2e8f0;
      background: rgba(255, 255, 255, 0.88);
      color: var(--text-soft);
      font-size: .9rem;
      font-weight: 700;
      transition: all .18s ease;
      cursor: pointer;
    }

    .pos-chip:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(15, 23, 42, 0.06);
    }

    .pos-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: currentColor;
      opacity: .9;
    }

    .pos-chip.active[data-pos="n"] { color: var(--noun); background: rgba(239, 246, 255, 0.9); border-color: rgba(96, 165, 250, 0.7); }
    .pos-chip.active[data-pos="v"] { color: var(--verb); background: rgba(254, 242, 242, 0.92); border-color: rgba(248, 113, 113, 0.7); }
    .pos-chip.active[data-pos="a"] { color: var(--adj); background: rgba(236, 253, 245, 0.92); border-color: rgba(74, 222, 128, 0.7); }
    .pos-chip.active[data-pos="d"] { color: var(--adv); background: rgba(255, 247, 237, 0.92); border-color: rgba(251, 191, 36, 0.7); }
    .pos-chip.active[data-pos="c"] { color: var(--conj); background: rgba(253, 242, 248, 0.92); border-color: rgba(244, 114, 182, 0.7); }
    .pos-chip.active[data-pos="o"] { color: var(--other); background: rgba(248, 250, 252, 0.95); border-color: rgba(148, 163, 184, 0.7); }

    .stat-card {
      border-radius: 1.35rem;
      border: 1px solid #e2e8f0;
      background: rgba(255, 255, 255, 0.88);
      padding: 1rem 1.1rem;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .tab-btn {
      border: 1px solid #e2e8f0;
      background: #fff;
      color: #64748b;
      padding: .65rem 1rem;
      border-radius: .95rem;
      font-weight: 800;
      font-size: .92rem;
      transition: all .18s ease;
    }

    .tab-btn.active {
      color: #7e22ce;
      background: #faf5ff;
      border-color: #d8b4fe;
      box-shadow: 0 8px 20px rgba(168, 85, 247, 0.08);
    }

    .ghost-btn,
    .action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .55rem;
      min-height: 42px;
      border-radius: 1rem;
      font-weight: 800;
      transition: all .18s ease;
      cursor: pointer;
    }

    .ghost-btn {
      border: 1px solid #e2e8f0;
      background: rgba(255, 255, 255, 0.9);
      color: #64748b;
      padding: .7rem 1rem;
    }

    .ghost-btn:hover {
      color: #7e22ce;
      border-color: #d8b4fe;
      background: #faf5ff;
    }

    .action-btn {
      border: 0;
      padding: .95rem 1.25rem;
      color: white;
      background: linear-gradient(135deg, #9333ea 0%, #7c3aed 50%, #6366f1 100%);
      box-shadow: 0 18px 35px rgba(126, 34, 206, 0.22);
    }

    .action-btn:hover { transform: translateY(-1px); }
    .action-btn:active { transform: translateY(0); }
    .action-btn:disabled,
    .ghost-btn:disabled { opacity: .65; cursor: not-allowed; transform: none; }

    .metric-label {
      font-size: .78rem;
      color: #94a3b8;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    .metric-value {
      font-size: 1.2rem;
      font-weight: 900;
      color: #334155;
    }

    .status-banner {
      border-radius: 1.25rem;
      padding: 1rem 1.1rem;
      border: 1px solid transparent;
      display: flex;
      align-items: flex-start;
      gap: .85rem;
    }

    .status-empty { background: #f8fafc; border-color: #e2e8f0; color: #64748b; }
    .status-loading { background: #faf5ff; border-color: #e9d5ff; color: #7e22ce; }
    .status-success { background: #ecfdf5; border-color: #a7f3d0; color: #047857; }
    .status-error { background: #fef2f2; border-color: #fecaca; color: #b91c1c; }

    .loader {
      width: 20px;
      height: 20px;
      border: 3px solid rgba(168, 85, 247, 0.2);
      border-top-color: var(--brand);
      border-radius: 999px;
      animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .result-table {
      width: 100%;
      border-collapse: collapse;
    }

    .result-table th,
    .result-table td {
      padding: .8rem .95rem;
      text-align: left;
      border-bottom: 1px solid #f1f5f9;
      font-size: .93rem;
    }

    .result-table th {
      position: sticky;
      top: 0;
      background: rgba(248, 250, 252, 0.98);
      color: #475569;
      font-size: .8rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      font-weight: 800;
    }

    .preview-shell {
      min-height: 560px;
      border-radius: 1.75rem;
      border: 1px solid rgba(226, 232, 240, 0.9);
      background:
        radial-gradient(circle at top left, rgba(233, 213, 255, 0.45), transparent 30%),
        linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
      overflow: hidden;
      position: relative;
    }

    .preview-shell::after {
      content: '';
      position: absolute;
      inset: 1rem;
      border: 1px dashed rgba(216, 180, 254, 0.5);
      border-radius: 1.25rem;
      pointer-events: none;
    }

    #canvas-wrapper {
      position: relative;
      min-height: 520px;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #word-cloud-canvas {
      width: 100%;
      height: 100%;
      display: block;
      max-width: 100%;
      max-height: 100%;
    }

    .empty-art {
      width: 96px;
      height: 96px;
      border-radius: 2rem;
      background: linear-gradient(135deg, rgba(233, 213, 255, 0.85), rgba(224, 231, 255, 0.85));
      display: grid;
      place-items: center;
      color: #7e22ce;
      margin: 0 auto 1rem;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.7), 0 20px 35px rgba(126, 34, 206, 0.08);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 24px;
      transform: translateX(-50%) translateY(18px);
      opacity: 0;
      pointer-events: none;
      transition: all .25s ease;
      z-index: 50;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    #pdf-generator-container {
      position: fixed;
      left: -9999px;
      top: 0;
      width: 1080px;
      background: #fff;
      padding: 40px;
      z-index: -10;
    }

    @media (max-width: 1024px) {
      .preview-shell { min-height: 460px; }
      #canvas-wrapper { min-height: 420px; }
    }
  </style>
</head>
<body>
  <nav class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/85 backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
      <button id="back-link-trigger" class="group inline-flex items-center gap-3 rounded-2xl border border-slate-200 bg-white/90 px-4 py-2.5 text-left shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:bg-brand-50">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-100 text-brand-700 transition group-hover:bg-brand-600 group-hover:text-white">
          <i class="fa-solid fa-arrow-left"></i>
        </span>
        <span>
          <span class="block text-sm font-bold text-slate-700" data-i18n="back">返回研究中心</span>
          <span class="block text-xs text-slate-400" data-i18n="back_hint">回到上一個教學工作區</span>
        </span>
      </button>

      <div class="flex items-center gap-3">
        <span class="nav-chip hidden sm:inline-flex">
          <i class="fa-solid fa-cloud"></i>
          <span data-i18n="tool_badge">教師分析工具</span>
        </span>
        <select id="language-selector" class="focus-ring rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm">
          <option value="zh-TW">繁體中文</option>
          <option value="en">English</option>
          <option value="ja">日本語</option>
          <option value="zh-CN">简体中文</option>
        </select>
      </div>
    </div>
  </nav>

  <main class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:py-8">
    <section class="mb-6">
      <div class="glass-panel rounded-[2rem] px-6 py-7 sm:px-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="mb-2 inline-flex items-center gap-2 rounded-full bg-brand-50 px-3 py-1 text-xs font-black uppercase tracking-[0.18em] text-brand-700">
              <i class="fa-solid fa-sparkles"></i>
              <span data-i18n="hero_kicker">Professor Workspace</span>
            </p>
            <h1 class="title-3d text-3xl font-black tracking-tight sm:text-4xl" data-i18n="title">AI 智能文字雲</h1>
            <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 sm:text-base" data-i18n="subtitle">
              以教師工作區的分析視角，快速整理文本核心概念、語意重點與詞性分布。
            </p>
          </div>

          <div class="grid grid-cols-2 gap-3 sm:flex sm:flex-wrap">
            <div class="stat-card min-w-[140px]">
              <div class="metric-label" data-i18n="metric_total_terms">分析詞彙</div>
              <div id="metric-total-terms" class="metric-value mt-1">0</div>
            </div>
            <div class="stat-card min-w-[140px]">
              <div class="metric-label" data-i18n="metric_visible_terms">目前顯示</div>
              <div id="metric-visible-terms" class="metric-value mt-1">0</div>
            </div>
            <div class="stat-card min-w-[160px] col-span-2 sm:col-span-1">
              <div class="metric-label" data-i18n="metric_top_word">最高權重</div>
              <div id="metric-top-word" class="metric-value mt-1 truncate">-</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[420px_minmax(0,1fr)]">
      <aside class="glass-panel rounded-[2rem] p-5 shadow-soft sm:p-6">
        <div class="mb-6 flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-black text-slate-800" data-i18n="input_title">文字輸入與設定</h2>
            <p class="mt-1 text-sm text-slate-500" data-i18n="input_desc">貼上教材、學生回應或研究文本後開始分析。</p>
          </div>
          <span class="nav-chip">
            <i class="fa-solid fa-wand-magic-sparkles"></i>
            <span data-i18n="mode_chip">Word Cloud</span>
          </span>
        </div>

        <label class="mb-2 block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_text">輸入文本</label>
        <textarea id="text-input" class="focus-ring min-h-[220px] w-full rounded-[1.5rem] border border-slate-200 bg-white/90 px-4 py-4 text-base leading-8 text-slate-700 shadow-inner resize-y" data-i18n-placeholder="placeholder_text"></textarea>

        <div class="mt-4 flex flex-wrap gap-3">
          <button id="btn-example" class="ghost-btn">
            <i class="fa-solid fa-flask"></i>
            <span data-i18n="btn_example">載入範例</span>
          </button>
          <button id="btn-clear" class="ghost-btn">
            <i class="fa-solid fa-trash-can"></i>
            <span data-i18n="btn_clear">清空</span>
          </button>
        </div>

        <div class="mt-6 space-y-5 rounded-[1.6rem] border border-slate-200 bg-slate-50/80 p-5">
          <div class="grid gap-5 sm:grid-cols-3">
            <div>
              <label class="mb-2 block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_model">權重模型</label>
              <div class="relative">
                <select id="model-select" class="focus-ring w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 shadow-sm">
                  <option value="frequency" data-i18n="opt_freq">詞頻 (Frequency)</option>
                  <option value="tfidf" data-i18n="opt_tfidf">TF-IDF (Intra-text)</option>
                  <option value="textrank" data-i18n="opt_textrank">TextRank (Weighted)</option>
                </select>
                <i class="fa-solid fa-chevron-down pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-xs text-slate-400"></i>
              </div>
            </div>

            <div>
              <label class="mb-2 block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_font">文字字體</label>
              <div class="relative">
                <select id="font-select" class="focus-ring w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 shadow-sm">
                  <option value="sans" data-i18n="font_sans">現代黑體</option>
                  <option value="serif" data-i18n="font_serif">教科書明體</option>
                  <option value="playful" data-i18n="font_playful">手寫展示</option>
                </select>
                <i class="fa-solid fa-chevron-down pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-xs text-slate-400"></i>
              </div>
            </div>

            <div>
              <label class="mb-2 block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_shape">雲圖形狀</label>
              <div class="relative">
                <select id="shape-select" class="focus-ring w-full appearance-none rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 shadow-sm">
                  <option value="circle" data-i18n="shape_circle">圓形</option>
                  <option value="square" data-i18n="shape_square">方形</option>
                  <option value="cardioid" data-i18n="shape_heart">愛心</option>
                  <option value="diamond" data-i18n="shape_diamond">菱形</option>
                  <option value="triangle-forward" data-i18n="shape_triangle">三角形</option>
                </select>
                <i class="fa-solid fa-chevron-down pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-xs text-slate-400"></i>
              </div>
            </div>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between gap-4">
              <label class="block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_max_words">顯示詞彙數量</label>
              <span id="max-words-val" class="rounded-full border border-brand-200 bg-white px-3 py-1 text-sm font-black text-brand-700">100</span>
            </div>
            <input id="max-words-slider" type="range" min="20" max="200" step="10" value="100" class="h-2 w-full cursor-pointer appearance-none rounded-full bg-slate-200 accent-brand-600">
          </div>

          <div>
            <div class="mb-3 flex items-center justify-between gap-3">
              <label class="block text-sm font-black uppercase tracking-[0.14em] text-slate-500" data-i18n="label_pos_filter">詞性過濾</label>
              <span class="text-xs font-bold text-slate-400" data-i18n="label_pos_hint">點擊切換顯示</span>
            </div>

            <div id="pos-container" class="flex flex-wrap gap-3">
              <button type="button" class="pos-chip active" data-pos="n"><span class="pos-dot"></span><span data-i18n="pos_n">名詞 (N)</span></button>
              <button type="button" class="pos-chip active" data-pos="v"><span class="pos-dot"></span><span data-i18n="pos_v">動詞 (V)</span></button>
              <button type="button" class="pos-chip active" data-pos="a"><span class="pos-dot"></span><span data-i18n="pos_a">形容詞 (A)</span></button>
              <button type="button" class="pos-chip" data-pos="d"><span class="pos-dot"></span><span data-i18n="pos_d">副詞 (D)</span></button>
              <button type="button" class="pos-chip" data-pos="c"><span class="pos-dot"></span><span data-i18n="pos_c">連接詞 (C)</span></button>
              <button type="button" class="pos-chip" data-pos="o"><span class="pos-dot"></span><span data-i18n="pos_o">其他 (O)</span></button>
            </div>
          </div>
        </div>

        <div class="mt-6">
          <button id="btn-analyze" class="action-btn w-full text-base">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span data-i18n="btn_visualize">產生文字雲</span>
          </button>
        </div>

        <div id="status-banner" class="status-banner status-empty mt-5">
          <i id="status-icon" class="fa-regular fa-circle mt-1"></i>
          <div>
            <div id="status-title" class="font-bold" data-i18n="state_ready">準備就緒</div>
            <div id="status-message" class="mt-1 text-sm" data-i18n="state_ready_desc">輸入文本後即可計算詞彙權重、AI 洞察與下載報告。</div>
          </div>
        </div>
      </aside>

      <section class="space-y-6">
        <div class="glass-panel rounded-[2rem] p-5 shadow-soft sm:p-6">
          <div class="mb-5 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
